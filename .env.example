# MongoDB
MONGODB_URI=mongodb://localhost:27017/radhe-boutique
# or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/radhe-boutique

# NextAuth
NEXTAUTH_SECRET=your-secret-key-min-32-characters-long
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id

# Resend (Email)
RESEND_API_KEY=your-resend-api-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp (order management)
# WHATSAPP_PROVIDER: "wa_me" (default, opens wa.me links) or "api" (future Business API)
WHATSAPP_PROVIDER=wa_me
# Required only when WHATSAPP_PROVIDER=api (WhatsApp Business Cloud API)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# Business Details
NEXT_PUBLIC_BRAND_NAME=Radhe Boutique
NEXT_PUBLIC_BRAND_TAGLINE=Crafted for Eternity
NEXT_PUBLIC_BRAND_CITY=Mumbai
NEXT_PUBLIC_BRAND_WHATSAPP=+919876543210
NEXT_PUBLIC_BRAND_EMAIL=info@radheboutique.com
NEXT_PUBLIC_BRAND_INSTAGRAM=@radheboutique
